{
  "name": "riq-store-platform",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "mobile",
    "packages/*"
  ],
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-test-renderer": "19.2.0",
    "react-native": "0.83.4",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.23.0"
  },
  "scripts": {
    "dev": "vite",
    "seo:assets": "node scripts/generate-seo-assets.mjs",
    "mobile:assets": "powershell -ExecutionPolicy Bypass -File scripts/generate-mobile-brand-assets.ps1",
    "build": "npm run seo:assets && tsc -b && vite build",
    "mobile:dev": "npm --workspace mobile run dev",
    "mobile:preflight": "powershell -ExecutionPolicy Bypass -File scripts/mobile-release-preflight.ps1",
    "mobile:typecheck": "npm --workspace mobile run typecheck",
    "mobile:doctor": "npm --workspace mobile run doctor",
    "mobile:test": "npm --workspace mobile run test",
    "mobile:login": "cd mobile && npx eas-cli login",
    "mobile:project:init": "cd mobile && npx eas-cli project:init",
    "mobile:whoami": "cd mobile && npx eas-cli whoami",
    "mobile:build:android": "npm --workspace mobile run build:android",
    "mobile:build:ios": "npm --workspace mobile run build:ios",
    "mobile:build:preview:android": "npm --workspace mobile run build:preview:android",
    "mobile:submit:android": "npm --workspace mobile run submit:android",
    "mobile:submit:ios": "npm --workspace mobile run submit:ios",
    "shared:test": "npm exec vitest run packages/shared/tests/shared.test.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "web:package:hostinger": "npm run build && powershell -ExecutionPolicy Bypass -File scripts/package-hostinger-release.ps1"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@riq/shared": "file:packages/shared",
    "@studio-freight/lenis": "^1.0.42",
    "@supabase/supabase-js": "^2.103.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "gsap": "^3.14.2",
    "i18next": "^25.10.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.562.0",
    "next-themes": "^0.4.6",
    "react": "19.2.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.70.0",
    "react-i18next": "^16.6.1",
    "react-resizable-panels": "^4.2.2",
    "react-router-dom": "^7.13.1",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "kimi-plugin-inspect-react": "^1.0.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^3.2.4"
  }
}
